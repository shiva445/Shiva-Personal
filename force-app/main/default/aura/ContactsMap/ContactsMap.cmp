<aura:component controller="ContactsMapCtrl" implements="flexipage:availableForAllPageTypes,force:hasRecordId">
	
    <aura:attribute name="mapMarkersData" type="Object[]"/>
    <aura:attribute name="recordId" type="Id"/>
    <aura:handler name="init" value="{! this }" action="{! c.doInit }"/>
    
    <aura:if isTrue="{!v.mapMarkersData.length > 0}" >
        <!-- the map component -->
        <lightning:map mapMarkers="{! v.mapMarkersData }" 
                       
                       />
    </aura:if>
    
    
</aura:component>